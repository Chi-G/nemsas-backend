# ============================================================================
# NEMSAS FastAPI - Environment Configuration
# ============================================================================
# Copy this file to .env and replace values with your actual configuration
# IMPORTANT: Never commit .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://nemsas:your_secure_password@db:5432/nemsas_db

# Database credentials for docker-compose / Setup
POSTGRES_USER=nemsas
POSTGRES_PASSWORD=your_secure_password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=nemsas_db

# ============================================================================
# SECURITY
# ============================================================================
# Secret key - use a long, random string (min 32 characters)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
DEBUG=true
DEPLOY_PORT=8000
PROJECT_NAME="NEMSAS Backend"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# ============================================================================
# PUSH NOTIFICATIONS & CACHING
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Firebase Service Account JSON Path
# Get this from Firebase Console > Settings > Service Accounts > Generate new private key
# Default relative path in root of backend directory: nemsas-app-firebase.json
FIREBASE_SERVICE_ACCOUNT_PATH=nemsas-app-firebase.json

# ============================================================================
# CLOUDINARY CONFIGURATION (For Claims Image Uploads)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================================================
# MAIL CONFIGURATION (Mailtrap recommended for Dev)
# ============================================================================
MAIL_SERVER="sandbox.smtp.mailtrap.io"
MAIL_PORT=2525
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM="noreply@nemsas.gov.ng"
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ============================================================================
# OPERATIONAL CONSTANTS (Rates in NGN)
# ============================================================================
BLS_FIXED_RATE=15000
ALS_VARIABLE_BASE_RATE=25000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
