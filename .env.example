# ============================================================================
# NEMSAS FastAPI - Environment Configuration
# ============================================================================
# Copy this file to .env and replace values with your actual configuration
# IMPORTANT: Never commit .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://nemsas:your_secure_password@db:5432/nemsas_db

# Database credentials for docker-compose
DB_USER=nemsas
DB_PASSWORD=your_secure_password
DB_NAME=nemsas_db
DB_HOST=db
DB_PORT=5432

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret key - use a long, random string (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Key for external services (if needed)
# API_KEY=your-api-key

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================
# Options: development, staging, production
ENVIRONMENT=dev

# Debug mode - MUST be false in production
DEBUG=false

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Port for the application (used by docker-compose)
DEPLOY_PORT=8000

# Application name
APP_NAME=NEMSAS

# Application version
APP_VERSION=0.1.0

# ============================================================================
# EMAIL CONFIGURATION (if applicable)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@nemsas.com

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# LOGGING
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# REDIS (if using caching)
# ============================================================================
# REDIS_URL=redis://redis:6379/0

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Add any external service credentials here
# SERVICE_API_KEY=your-key
